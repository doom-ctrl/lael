# ─── Lael — Environment Variables ─────────────────────────────────────────
#
# Copy this file to `.env.local` and fill in real values. Vite reads
# variables prefixed with `VITE_`; Convex reads everything else.
#
# The Vite dev server picks up `.env.local` automatically. Convex
# picks up `.env.local` (and any values you set with `bunx convex
# env set`) for the dev deployment. For production, set these in
# the Vercel project and via `bunx convex env set --prod`.
#
# ─── Frontend (Vite, exposed to the browser via `import.meta.env`) ─────────

# Public Convex deployment URL — generated by `bunx convex dev` and
# written to `.env.local` automatically. Safe to commit the
# variable name; the value is per-deployment.
VITE_CONVEX_URL=

# Public site URL — used for auth redirects and email links. In dev
# this is `http://localhost:5173`; in prod it's the deployed origin.
VITE_SITE_URL=http://localhost:5173

# ─── Convex backend (server-side only, never exposed to the client) ───────

# Better Auth — secret used to sign session tokens. Generate with
# `openssl rand -hex 32`. Set the same value in Vercel + Convex.
BETTER_AUTH_SECRET=

# Brevo — transactional email (daily digest + Better Auth flows:
# email verification, password reset, change-email confirmations).
#
# Setup (free tier, no custom domain required, ~5 minutes):
#   1. Sign up at https://www.brevo.com (no credit card).
#   2. Settings → Senders, Domains, IPs → Senders → Add a sender.
#      Use a Gmail / Outlook address you control; Brevo will email
#      a 6-digit code to that inbox — paste it back to verify.
#   3. Settings → SMTP & API → API keys → Generate a new API key.
#   4. Set the three values below. `BREVO_FROM_NAME` is the display
#      name shown in recipients' inboxes (default: "Lael").
#
# Free tier: 300 emails/day forever. Generous for Lael's scale.
# When you add a custom domain later, authenticate it in Brevo and
# update `BREVO_FROM_EMAIL` to an address on that domain — no code
# changes needed.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Lael

# Sentry — optional error monitoring. DSN is the only required
# value; leave blank to disable.
SENTRY_DSN=

# Plausible — optional privacy-friendly analytics. The domain is
# the site you're tracking (no protocol). Leave blank to disable.
VITE_PLAUSIBLE_DOMAIN=
